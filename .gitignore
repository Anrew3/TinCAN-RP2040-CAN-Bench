# TinCAN CAN-BUS Simulator .gitignore

# Claude AI session files
.claude/
*.claude
claude-*
CLAUDE.md

# Personal/Private files
*.private
*.personal
notes-personal.*

# IDE and Editor files
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Build outputs (Arduino "Export Compiled Binary").
# Track ONLY the exported .uf2 inside the sketch build folder (the web flasher
# serves it); ignore everything else in there and the heavy artifacts anywhere.
/firmware/can_sim/build/**
!/firmware/can_sim/build/**/
!/firmware/can_sim/build/**/*.uf2
*.elf
*.hex
*.bin
*.map
*.eep

# Temporary files
*.tmp
*.temp
*.bak

# Logs
*.log
