{
  "$schema": "./schema.json",
  "name": "Ford Mustang S550",
  "id": "mustang_s550",
  "version": "1.0.0",
  "author": "TinCAN Community",
  "description": "CAN bus template for Ford Mustang S550 platform (2015-2023). Includes support for instrument cluster, steering wheel controls, TPMS, and turn signals.",

  "vehicle": {
    "make": "Ford",
    "model": "Mustang",
    "years": "2015-2023",
    "platform": "S550"
  },

  "buttons": {
    "canId": "0x81",
    "holdMs": 100,
    "intervalMs": 10,
    "default": "00 00 00 00 00 00 00 00",
    "commands": {
      "UP": "08 00 00 00 00 00 00 00",
      "DOWN": "01 00 00 00 00 00 00 00",
      "LEFT": "02 00 00 00 00 00 00 00",
      "RIGHT": "04 00 00 00 00 00 00 00",
      "OK": "10 00 00 00 00 00 00 00",
      "SETTINGS": "46 01 00 00 00 00 00 00"
    }
  },

  "gauges": {
    "RPM": {
      "canId": "0x204",
      "base": "00 00 00 00 00 00 00 00",
      "valueBytes": [3, 4],
      "scale": 0.5,
      "offset": 0,
      "min": 0,
      "max": 8000,
      "unit": "rpm",
      "intervalMs": 100
    },
    "SPEED": {
      "canId": "0x202",
      "base": "00 00 00 00 60 00 00 00",
      "valueBytes": [6, 7],
      "scale": 159,
      "offset": 0,
      "min": 0,
      "max": 200,
      "unit": "mph",
      "intervalMs": 100
    },
    "FUEL": {
      "canId": "0x207",
      "base": "00 00 00 00 00 00 00 00",
      "valueBytes": [2],
      "scale": 2.55,
      "offset": 0,
      "min": 0,
      "max": 100,
      "unit": "%",
      "intervalMs": 200
    }
  },

  "temperature": {
    "canId": "0x156",
    "base": "00 00 00 00 03 00 00 00",
    "intervalMs": 100,
    "sensors": {
      "COOLANT": {
        "byte": 0,
        "formula": "(value - 32) * 5 / 9 + 60"
      },
      "OIL": {
        "byte": 1,
        "formula": "(value - 32) * 5 / 9 + 60"
      }
    }
  },

  "tpms": {
    "canId": "0x3B5",
    "base": "00 00 00 00 00 00 00 00",
    "intervalMs": 200,
    "inputUnit": "psi",
    "tires": {
      "FL": { "byte": 1, "scale": 6.895 },
      "FR": { "byte": 3, "scale": 6.895 },
      "RL": { "byte": 7, "scale": 6.895 },
      "RR": { "byte": 5, "scale": 6.895 }
    }
  },

  "blinkers": {
    "canId": "0x3B3",
    "canIdAlt": "0x3B2",
    "base": "40 48 C0 10 10 00 00 02",
    "wakeBase": "41 00 00 00 4C 00 00 00",
    "wakeDefault": true,
    "intervalMs": 10,
    "blinkRateMs": 500,
    "left": {
      "byte": 6,
      "mask": "0x40"
    },
    "right": {
      "byte": 4,
      "mask": "0x08"
    }
  },

  "vin": {
    "canId": "0x40A",
    "intervalMs": 200,
    "format": "multiframe",
    "framePrefix": "C1"
  },

  "background": [
    {
      "canId": "0x109",
      "data": "00 03 01 00 00 00 00 28",
      "intervalMs": 10,
      "description": "Cluster keepalive"
    },
    {
      "canId": "0x416",
      "data": "50 00 FE 00 01 00 00 00",
      "intervalMs": 10,
      "description": "ABS/Traction control status"
    },
    {
      "canId": "0x171",
      "data": "00 00 00 00 00 00 00 00",
      "intervalMs": 10,
      "description": "Gear / reverse (Sync 4) - overlaid by GEAR signal"
    },
    {
      "canId": "0x048",
      "data": "00 00 00 00 07 00 E0 00",
      "intervalMs": 10,
      "description": "C1MCA turn-on - SYNC wake sequence"
    }
  ],
  "signals": [
    {
      "name": "GEAR",
      "canId": "0x171",
      "startByte": 0,
      "default": "PARK",
      "states": { "PARK": "00 00", "REVERSE": "36 32", "NEUTRAL": "00 00", "DRIVE": "00 00" },
      "description": "Gear selector; REVERSE sets 0x171 B0/B1"
    },
    {
      "name": "HEADLIGHTS",
      "canId": "0x3B3",
      "startByte": 0,
      "default": "DRL",
      "states": { "DRL": "40 48", "ON": "44 88" },
      "description": "0x3B2/3 B0+B1 headlight switch, written as a pair: DRL/daytime (B0=40,B1=48) or headlamps on/night (B0=44,B1=88). Hazard lives in the Turn Signals control (B4/B6)."
    },
    {
      "name": "BACKLIGHT",
      "canId": "0x3B3",
      "startByte": 3,
      "numeric": true,
      "min": 0,
      "max": 17,
      "states": { "OFF": "00", "MYCOLOR": "0A", "MAX": "11" },
      "description": "0x3B2/3 B3 cluster/display brightness (0-17)"
    },
    {
      "name": "DAYNIGHT",
      "canId": "0x3B3",
      "startByte": 5,
      "default": "DAY",
      "states": { "DAY": "00", "NIGHT": "50" },
      "description": "0x3B2/3 B5 day/night dimming"
    },
    {
      "name": "DOORS",
      "canId": "0x3B3",
      "startByte": 7,
      "default": "CLOSED",
      "states": { "CLOSED": "02", "PASSENGER": "12", "DRIVER": "22", "BOTH": "32", "HOODOPEN": "0A" },
      "description": "0x3B2/3 B7 doors + hood"
    },
    {
      "name": "ABS",
      "canId": "0x416",
      "startByte": 6,
      "default": "OFF",
      "states": { "OFF": "00", "SOLID": "40", "SLOW": "80", "FAST": "D0" },
      "description": "0x416 B6 ABS warning light"
    },
    {
      "name": "TRACTION",
      "canId": "0x416",
      "startByte": 5,
      "default": "OFF",
      "states": { "OFF": "00", "SOLID": "02", "FLASH": "0F" },
      "description": "0x416 B5 traction control light"
    }
  ]
}
